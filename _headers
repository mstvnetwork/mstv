# 1. SECURITY & DOMAIN LOCK (The "Hard Lock")
/*
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Cross-Origin-Opener-Policy: same-origin
  X-Frame-Options: SAMEORIGIN
  
  # Hardened CSP: Optimized to remove "High Severity" flags while allowing CDN scripts & GoatCounter
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://gc.zgo.at; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://gc.zgo.at; connect-src 'self' https://gc.zgo.at https://*.m3u8 https://*.ts https://*.mpd; frame-src 'self' *; object-src 'none'; base-uri 'self'; frame-ancestors 'self' https://mstvnet.netlify.app;

# 2. DATA ACCESS (API & JSON)
/channels2.json
  Cache-Control: public, max-age=3600, must-revalidate
  Access-Control-Allow-Origin: https://mstvnet.netlify.app

# 3. STATIC ASSETS (Performance - 1 Year Cache)
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, immutable

# 4. SEO & SEARCH CRITICAL
/sitemap.xml
  Content-Type: application/xml
  X-Content-Type-Options: nosniff
