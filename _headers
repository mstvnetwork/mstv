# 1. DATA ACCESS
/channels.json
  Cache-Control: public, max-age=3600, must-revalidate
  Access-Control-Allow-Origin: *

/channels2.json
  Cache-Control: public, max-age=300, must-revalidate
  Access-Control-Allow-Origin: *

# 2. STATIC ASSETS (Performance)
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, immutable

# 3. GLOBAL SECURITY & SEO
/*
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://gc.zgo.at blob:; style-src 'self' 'unsafe-inline'; frame-src *; img-src * data:; connect-src * blob:; media-src * blob:; font-src 'self' data:; worker-src blob:; object-src 'none'; base-uri 'self'
  Cross-Origin-Opener-Policy: same-origin-allow-popups

/sitemap.xml
  Content-Type: application/xml
  X-Content-Type-Options: nosniff
