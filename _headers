# 1. DATA ACCESS & SECURITY LOCK
/*
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  # This line prevents ANYONE else from putting your site in an iframe
  Content-Security-Policy: frame-ancestors 'self' https://mstvnet.netlify.app;
  X-Frame-Options: SAMEORIGIN

/channels2.json
  Cache-Control: public, max-age=3600, must-revalidate
  Access-Control-Allow-Origin: https://mstvnet.netlify.app

# 2. STATIC ASSETS (Performance)
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, immutable

# 3. SEO
/sitemap.xml
  Content-Type: application/xml
  X-Content-Type-Options: nosniff
